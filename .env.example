# Environment variables for ChainLens Trading System

# Database
DATABASE_URL=postgresql://localhost/chainlens

# Wallet (for live trading - KEEP SECRET!)
WALLET_PRIVATE_KEY=
WALLET_ADDRESS=

# OKX OnchainOS API (optional)
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# Notifications (optional)
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Trading Mode
TRADING_MODE=paper  # paper or live
